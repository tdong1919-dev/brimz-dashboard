# Copy to .env and fill in. Never commit the real .env.
# Docker Postgres is published on host port 5433 (host :5432 is taken by a local cluster).
DATABASE_URL=postgresql+psycopg://brimz:brimz@localhost:5433/brimz

# Fitbit — only needed live in Milestone 4. M1–M3 run on fixtures.
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Number of detailed attendee rows to generate (headline attendance is stored separately).
SEED_ATTENDEES=500

# --- API + playback engine (Milestone 2) ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed to call the API (the dashboard dev server).
API_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
# Wall-clock seconds for one full replay loop of an event window (300 => a 5h event loops every 5 min).
PLAYBACK_LOOP_SECONDS=300
# How often the live WebSocket pushes a tick (wall-clock seconds).
PLAYBACK_TICK_SECONDS=2
# Which event the playback engine drives by default (the fully-simulated demo event).
PLAYBACK_DEFAULT_EVENT_ID=1
